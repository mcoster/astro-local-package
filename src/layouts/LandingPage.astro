---
export interface Props {
  title?: string;
  description?: string;
  noindex?: boolean;
  logo?: string;
  trustPhrase?: string;
  footerLinks?: Array<{ label: string; href: string }>;
  schema?: any;
  schemaItems?: any;
  faqs?: Array<{ question: string; answer: string }>;
  includeLocalBusiness?: boolean;
}

import Layout from './Layout.astro';
import LandingPageHeader from '../components/LandingPageHeader.astro';
import LandingPageFooter from '../components/LandingPageFooter.astro';

const {
  title,
  description,
  noindex = true,
  logo,
  trustPhrase,
  footerLinks,
  schema,
  schemaItems,
  faqs,
  includeLocalBusiness,
} = Astro.props;
---

<Layout
  title={title}
  description={description}
  noindex={noindex}
  schema={schema}
  schemaItems={schemaItems}
  faqs={faqs}
  includeLocalBusiness={includeLocalBusiness}
>
  <LandingPageHeader logo={logo} trustPhrase={trustPhrase} />
  <main>
    <slot />
  </main>
  <LandingPageFooter links={footerLinks} />
</Layout>
